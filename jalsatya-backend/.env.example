# App
APP_NAME=AquaPulse AI
APP_ENV=development
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://aquapulse:password@localhost:5432/aquapulse_db
DATABASE_URL_SYNC=postgresql://aquapulse:password@localhost:5432/aquapulse_db

# Redis + Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Sensor Mode
SENSOR_MODE=mock
MOCK_UPDATE_INTERVAL_SECONDS=5
MOCK_VILLAGE_COUNT=15

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2000

# AWS
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=aquapulse-documents
CLOUDFRONT_DOMAIN=your-cloudfront-domain

# Notifications
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
SENSOR_RATE_LIMIT_SECONDS=25
API_RATE_LIMIT_PER_MINUTE=100

# Initial Admin
ADMIN_EMAIL=admin@aquapulse.ai
ADMIN_PASSWORD=ChangeThisInProduction@2026
ADMIN_FULL_NAME=System Administrator
